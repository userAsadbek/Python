import re
name=input("What is your name? ")
matches=re.search(r"^(.+), (.+)$",name)
if matches:=re.search(r"^(.+), *(.+)$",name): # walrus operator
    name=matches.group(2) + " " + matches.group(1)
    # or 
    # last=matches.group(1)
    # first=matches.group(2) 
    # := walrus operator 
  
print(f"Hello, {name}")    
